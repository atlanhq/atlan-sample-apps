# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.

# The Atlan instance URL.
# In embedded mode: used for postMessage origin validation.
# In standalone mode: used for Keycloak PKCE authentication.
VITE_ATLAN_ORIGIN=https://YOUR_TENANT.atlan.com

# Optional: asset GUID for standalone dev (can also use ?assetId= URL param)
# VITE_ATLAN_ASSET_GUID=your-asset-guid-here
