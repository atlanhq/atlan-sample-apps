# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.

# --- Required for local dev mode ---

# Set to "true" to bypass the iframe postMessage handshake
# and use the token/GUID below instead.
VITE_DEV_MODE=true

# Your Atlan instance base URL (e.g. https://tenant.atlan.com)
# Used by the Vite dev server proxy to forward /api/meta/* requests.
VITE_ATLAN_BASE_URL=https://YOUR_TENANT.atlan.com

# A valid Atlan API bearer token.
# Generate one from: Atlan UI → Settings → API Tokens → Generate.
VITE_ATLAN_API_TOKEN=your-bearer-token-here

# The GUID of an asset to display.
# Find this in the asset URL: https://tenant.atlan.com/assets/<GUID>/overview
VITE_ATLAN_ASSET_GUID=your-asset-guid-here

# --- Optional ---

# Lock postMessage origin validation to a specific domain (production use).
# Leave unset or "*" to accept messages from any origin.
# VITE_ATLAN_ORIGIN=https://YOUR_TENANT.atlan.com
