# Copy to .env.local and fill in your values

# Enable dev mode — bypasses the Atlan iframe postMessage handshake
VITE_DEV_MODE=true

# Your Atlan tenant — Vite proxies /api/meta/* here to avoid CORS
VITE_ATLAN_BASE_URL=https://YOUR_TENANT.atlan.com

# Bearer token from Atlan Settings > API Tokens
VITE_ATLAN_API_TOKEN=your-bearer-token-here

# GUID of the asset you want to test with
# Grab from: https://tenant.atlan.com/assets/<GUID>/overview
VITE_ATLAN_ASSET_GUID=your-asset-guid-here

# Optional: lock postMessage to a specific origin (defaults to * in dev)
# VITE_ATLAN_ORIGIN=https://YOUR_TENANT.atlan.com
